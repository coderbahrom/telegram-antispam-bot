# ===== Telegram Anti-Spam Bot sozlamalari =====
# Bu faylni .env nomi bilan nusxalang va qiymatlarni to'ldiring:
#   cp .env.example .env

# @BotFather bergan bot tokeni (MAJBURIY)
BOT_TOKEN=

# Botni boshqara oladigan adminlar (Telegram user ID, vergul bilan).
# O'z ID'ingizni @userinfobot dan oling. Bo'sh bo'lsa — faqat guruh adminlari.
ADMIN_IDS=

# ===== CAPTCHA (qo'shilishda tekshiruv) =====
# Yangi a'zo tugmani bosmaguncha yoza olmaydi. Spamni eng kuchli to'xtatuvchi.
CAPTCHA_ENABLED=true
# Tugmani bosish uchun beriladigan vaqt (soniya). O'tib ketsa — chetlatiladi.
CAPTCHA_TIMEOUT=60

# ===== Spam filtri =====
# Spamga nisbatan harakat:
#   "hybrid" = porn/phishing (profilimga o'ting...) -> BAN, oddiy reklama -> OGOHLANTIRISH (tavsiya)
#   "warn"   = hammasini o'chir + ogohlantirish (ban YO'Q)
#   "ban"    = hammasini o'chir + ban
#   "delete" = faqat o'chir (jim)
SPAM_ACTION=hybrid
# Spam bali shu qiymatga yetса harakat qilinadi (default 3)
SPAM_THRESHOLD=3
# A'zo qo'shilgandan keyin necha soniya "yangi" hisoblanadi (qattiqroq tekshiruv)
NEW_USER_WINDOW=3600

# "warn" rejimi uchun ogohlantirish matni ({user} -> foydalanuvchi nomi)
WARN_TEXT=⚠️ {user}, bu guruhда reklama/spam taqiqlangan. Iltimos, reklama tarqatmang.
# Ogohlantirish necha soniyadan keyin o'zi o'chsin (0 = o'chmaydi)
WARN_DELETE_AFTER=15

# Guruhga kirish/chiqish xizmat xabarlarini avto-o'chirish (true/false)
DELETE_SERVICE_MESSAGES=true

# ===== NSFW (18+) profil rasmi tekshiruvi =====
# Qo'shilayotgan a'zoning profil rasmini lokal AI (NudeNet) bilan tekshiradi.
# 18+ rasm topilsa — darrov ban. Hammasi serverda, tashqi API yo'q.
NSFW_CHECK_ENABLED=true
# Ishonch bo'sag'asi (0..1). Kattaroq = ehtiyotkorroq (kamroq noto'g'ri ban).
NSFW_THRESHOLD=0.6

# ===== Log =====
# Ixtiyoriy: bot harakatlarini yozadigan chat ID (masalan -1001234567890).
# Bo'sh bo'lsa — faqat konsolga log yoziladi.
LOG_CHAT_ID=
